{
  "appId": "com.smartparking.client",
  "productName": "智慧停车场运营管理系统",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "SmartParking-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "public/favicon.ico",
    "createDesktopShortcut": true,
    "shortcutName": "智慧停车场运营管理系统"
  }
}
